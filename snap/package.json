    "serve": "mm-snap serve",
    "manifest": "mm-snap manifest --fix",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@metamask/snaps-sdk": "^6.24.0",
    "luxon": "^3.7.2",
    "viem": "^2.25.0"
  },
  "devDependencies": {
    "@metamask/snaps-cli": "^6.6.0",
    "@types/node": "^20.0.0",
    "rimraf": "^5.0.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
