# Beesnap install page (Next.js)
# ──────────────────────────────────────────────────────────────────────────
# The install page only needs to know which Snap id to install.
# - In dev:    `local:http://localhost:8080`  (matches `npm run snap:dev` / `snap/snap.config.ts`)
# - In prod:   put these in `.env.production.local` (see root README “Publishing new versions”):
#     NEXT_PUBLIC_SNAP_ID=npm:@beesnap/snap
#     NEXT_PUBLIC_SNAP_VERSION=0.1.3   # must match the version published on npm

NEXT_PUBLIC_SNAP_ID=local:http://localhost:8080
NEXT_PUBLIC_SNAP_VERSION=0.1.3

# Backend (`backend/.env`) — for reference only, the install page does not use these.
# CORS_ORIGIN=https://beeport.ethswarm.org
# PORT=3333
# PROXY_TARGET=http://localhost:1633
# REGISTRY_ADDRESS=0x5EBfBeFB1E88391eFb022d5d33302f50a46bF4f3
