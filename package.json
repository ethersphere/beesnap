{
  "name": "beesnap",
  "version": "2.0.0-snap.0",
  "private": true,
  "description": "Swarm bee snap integration with MetaMask Snaps. Minimal install dApp, Snap, and backend proxy.",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xCardiE/beesnap.git"
  },
  "homepage": "https://github.com/0xCardiE/beesnap",
  "bugs": {
    "url": "https://github.com/0xCardiE/beesnap/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "snap:build": "cd snap && npm run build",
    "snap:serve": "cd snap && npm run serve",
    "snap:dev": "cd snap && npm run dev",
    "snap:watch": "cd snap && npm run dev",
    "snap:install": "cd snap && npm install",
    "backend:dev": "cd backend && node index.js",
    "deploy:router": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat deploy --network gnosis --tags SushiSwapStampsRouter",
    "verify:router": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat run scripts/verify_router.ts --network gnosis",
    "verify:registry": "TS_NODE_PROJECT=tsconfig.hardhat.json npx hardhat run scripts/verify_registry.ts --network gnosis"
  },
  "dependencies": {
    "next": "14.2.15",
    "react": "^18",
    "react-dom": "^18"
  },
  "ts-node": {
    "project": "./tsconfig.hardhat.json",
    "transpileOnly": true
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-ethers": "^3.0.8",
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "@nomicfoundation/hardhat-verify": "^2.0.13",
    "@types/node": "^20.17.30",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "dotenv": "^16.5.0",
    "eslint": "^8",
    "eslint-config-next": "14.2.15",
    "eslint-config-prettier": "^10.1.3",
    "ethers": "^6.13.7",
    "hardhat": "^2.23.0",
    "hardhat-deploy": "^1.0.2",
    "prettier": "^3.5.3",
    "typescript": "^5"
  }
}
